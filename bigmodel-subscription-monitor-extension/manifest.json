{
  "manifest_version": 3,
  "name": "BigModel Subscription Monitor",
  "version": "0.1.0",
  "description": "Monitor BigModel GLM Coding subscription API responses and keep local logs.",
  "permissions": ["storage", "notifications", "tabs", "activeTab", "sidePanel", "webRequest"],
  "host_permissions": ["https://bigmodel.cn/*", "https://open.bigmodel.cn/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://bigmodel.cn/glm-coding*"],
      "js": ["shared.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js"],
      "matches": ["https://bigmodel.cn/*"]
    }
  ],
  "action": {
    "default_icon": "icon-128.png",
    "default_title": "BigModel Monitor"
  }
}
